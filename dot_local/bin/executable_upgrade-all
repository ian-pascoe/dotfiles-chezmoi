#!/usr/bin/env bash

#########################################################################
# Helpers
has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

has_service() {
  systemctl --user is-active --quiet "$1"
}

# Necessary for systemd service restarts
if has_cmd systemctl; then
  if [ -z "${XDG_RUNTIME_DIR:-}" ] && [ -d "/run/user/$(id -u)" ]; then
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
  fi

  if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -S "${XDG_RUNTIME_DIR}/bus" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"
  fi
fi

#########################################################################
# Start
START_TIME=$(date +%s)
echo "Starting upgrade process at $(date)..."

#########################################################################
# Homebrew/Linuxbrew
if has_cmd brew; then
  echo "Updating Homebrew and its packages..."
  brew update
  brew upgrade --greedy
  echo "Homebrew and its packages updated successfully!"
fi

#########################################################################
# Node
if has_cmd npm; then
  echo "Updating global npm modules..."
  npm update -g
  echo "Global npm modules updated successfully!"
fi

#########################################################################
# PNPM
if has_cmd pnpm; then
  echo "Updating global pnpm modules..."
  pnpm -g update --latest
  echo "Global pnpm modules updated successfully!"
fi

#########################################################################
# Bun
if has_cmd bun; then
  echo "Updating global bun modules..."
  bun -g update --latest
  echo "Global bun modules updated successfully!"
fi

#########################################################################
# Pip
if has_cmd pip; then
  echo "Updating Pip packages..."
  pip install --upgrade pip
  pip list --outdated --format=json | jq -r '.[].name' | xargs -r -n1 pip install -U
  echo "Pip packages updated successfully!"
fi

#########################################################################
# Pipx
if has_cmd pipx; then
  echo "Updating Pipx packages..."
  pipx upgrade-all
  echo "Pipx packages updated successfully!"
fi

#########################################################################
# UV
if has_cmd uv; then
  echo "Updating UV packages..."
  uv tool upgrade --all
  echo "UV packages updated successfully!"
fi

#########################################################################
# RustUp
if has_cmd rustup; then
  echo "Updating RustUp and its components..."
  rustup update
  echo "RustUp and its components updated successfully!"
fi

#########################################################################
# Cargo
if has_cmd cargo; then
  echo "Updating Cargo packages..."
  cargo install-update -a
  echo "Cargo packages updated successfully!"
fi

#########################################################################
# Mise
if has_cmd mise; then
  echo "Updating Mise packages..."
  mise upgrade --bump
  echo "Mise packages updated successfully!"
fi

#########################################################################
# Skills
SKILLS_CMD=()
if has_cmd skills; then
  SKILLS_CMD=("skills")
elif has_cmd npx; then
  SKILLS_CMD=("npx" "--yes" "skills@latest")
elif has_cmd pnpm; then
  SKILLS_CMD=("pnpm" "dlx" "skills@latest")
elif has_cmd bunx; then
  SKILLS_CMD=("bunx" "skills@latest")
fi
if [ ${#SKILLS_CMD[@]} -ne 0 ]; then
  echo "Updating global skills..."
  "${SKILLS_CMD[@]}" update -g
  echo "Global skills updated successfully!"
fi

#########################################################################
# Yazi
if has_cmd ya; then
  echo "Updating Yazi packages..."
  ya pkg upgrade
  echo "Yazi packages updated successfully!"
fi

####################################################################
# Camoufox browser
if has_cmd camoufox; then
  echo "Updating Camoufox browser..."
  camoufox fetch
  echo "Camoufox browser updated successfully!"
fi

####################################################################
# OpenCode Server
if has_cmd systemctl && has_service opencode.service; then
  echo "Restarting OpenCode server..."
  systemctl --user restart opencode.service
  echo "OpenCode server restarted successfully!"
fi

####################################################################
# Kimaki Server
if has_cmd systemctl && has_service kimaki.service; then
  echo "Restarting Kimaki server..."
  systemctl --user restart kimaki.service
  echo "Kimaki server restarted successfully!"
fi

####################################################################
# Dotfiles
if has_cmd chezmoi; then
  echo "Updating dotfiles..."
  (
    chezmoi git -- pull -ftr --autostash
  )
  echo "Dotfiles updated successfully!"
fi

####################################################################
# Local update script
if [ -x "$HOME/.local/bin/local-upgrade-all" ]; then
  echo "Running local update script..."
  "$HOME/.local/bin/local-upgrade-all"
  echo "Local update script completed successfully!"
fi

####################################################################
# Cleanup
if has_cmd brew; then
  echo "Cleaning up Homebrew cache..."
  brew cleanup -s
  brew autoremove
  echo "Homebrew cache cleaned successfully!"
fi
if has_cmd npm; then
  echo "Cleaning up npm cache..."
  npm cache clean --force
  echo "npm cache cleaned successfully!"
fi
if has_cmd pnpm; then
  echo "Cleaning up pnpm cache..."
  pnpm store prune
  pnpm cache delete
  echo "pnpm cache cleaned successfully!"
fi
if has_cmd bun; then
  echo "Cleaning up bun cache..."
  bun -g pm cache rm
  echo "bun cache cleaned successfully!"
fi
if has_cmd pip; then
  echo "Cleaning up Pip cache..."
  pip cache purge
  echo "Pip cache cleaned successfully!"
fi
if has_cmd pipx; then
  echo "Cleaning up Pipx cache..."
  rm -rf ~/.cache/pipx
  echo "Pipx cache cleaned successfully!"
fi
if has_cmd uv; then
  echo "Cleaning up uv cache..."
  uv cache clean
  echo "UV cache cleaned successfully!"
fi
if has_cmd cargo; then
  echo "Cleaning up cargo cache..."
  cargo cache -a
  echo "Cargo cache cleaned successfully!"
fi
if has_cmd mise; then
  echo "Cleaning up Mise cache..."
  mise cache clear
  echo "Mise cache cleaned successfully!"
fi
if has_cmd docker; then
  echo "Cleaning up Docker system..."
  docker system prune -af --volumes
  echo "Docker system cleaned successfully!"
fi
if has_cmd git; then
  echo "Running git garbage collection..."
  find "$HOME" -type d -name ".git" -prune -exec sh -c 'cd "$(dirname "{}")" && git gc --auto' \; >/dev/null 2>&1
  echo "Git garbage collection completed successfully!"
fi

####################################################################
# Finished
END_TIME=$(date +%s)
ELAPSED_TIME=$((END_TIME - START_TIME))

echo "All updates completed successfully in $ELAPSED_TIME seconds!"
echo "Finished upgrade process at $(date)."
