# === MK's Calendars (from MK's iCloud) ===
# Keep only calendars that appear unique in khal output.
# Duplicated shared calendars remain synced by vdirsyncer but are hidden here:
#   mk_03E6  ~= mk_calendar
#   mk_2cc8  ~= ians_work
#   mk_3ac3  ~= pascoe_family
#   mk_95bc  ~= ians_shared

[[mk_home]]
path = ~/.local/share/vdirsyncer/calendars/mk/home/
color = light magenta

[[mk_9f4d]]
