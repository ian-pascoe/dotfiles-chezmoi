{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@vectorize-io/opencode-hindsight"
  ],
  "autoupdate": "notify",
  "permission": {
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "google_search": "deny",
    "chrome-devtools*": "deny",
    "codesearch": "ask",
    "context7*": "ask",
    "deepwiki*": "ask",
    "grep-app*": "ask",
    "webfetch": "ask",
    "websearch": "ask"
  },
  "agent": {
    "build": {
      "model": "litellm/openai/gpt-5.4",
      "variant": "medium"
    },
    "plan": {
      "model": "litellm/openai/gpt-5.4",
      "variant": "high",
      "permission": {
        "edit": {
          "*": "deny",
          "AGENTS.md": "allow",
          "**/AGENTS.md": "allow",
          ".opencode/plans/**": "allow"
        }
      }
    },
    "explore": {
      "description": "Codebase exploration agent for local repository understanding. Use it to inspect project structure, find files/symbols, trace implementations, and answer questions about how code in this repo works. Prefer research for internet or external-source investigation.",
      "model": "litellm/openai/gpt-5.4-mini",
      "permission": {
        "skill": "allow",
        "codesearch": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "context7*": "deny",
        "deepwiki*": "deny",
        "grep-app*": "deny"
      }
    },
    "general": {
      "description": "Default balanced agent for most engineering tasks. Use for everyday coding, debugging, file edits, and command execution when you need solid quality without extreme latency or extreme depth. Escalate to quick for tiny tasks, deep for high-complexity analysis, and frontend-expert for UI-heavy work.",
      "model": "litellm/openai/gpt-5.4",
      "variant": "medium"
    },
    "research": {
      "description": "Web research subagent for external information gathering and synthesis. Use it for internet search, reading external docs/articles/issues, comparing sources, and producing evidence-based summaries. Prefer explore for local codebase inspection and in-repo implementation tracing.",
      "mode": "subagent",
      "model": "litellm/openai/gpt-5.4-mini",
      "permission": {
        "*": "deny",
        "bash": "allow",
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "skill": "allow",
        "codesearch": "allow",
        "context7*": "allow",
        "deepwiki*": "allow",
        "grep-app*": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "quick": {
      "description": "Speed-first subagent for low-complexity work. Use for quick lookups, short summaries, single-command checks, and small isolated edits where correctness is straightforward. If scope grows, uncertainty appears, or multiple systems are involved, switch to general or deep.",
      "mode": "subagent",
      "model": "litellm/openai/gpt-5.4",
      "variant": "low",
      "permission": {
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "deep": {
      "description": "Thorough reasoning subagent for complex or high-risk tasks. Use for difficult debugging, architecture decisions, multi-file refactors, root-cause analysis, and work with subtle trade-offs or edge cases. Prefer this when accuracy and completeness matter more than speed.",
      "mode": "subagent",
      "model": "litellm/openai/gpt-5.4",
      "variant": "high",
      "permission": {
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "frontend-expert": {
      "description": "Specialist for frontend and UX tasks. Use for building or refining components/pages, HTML/CSS/JavaScript framework work, responsive behavior, accessibility, visual polish, and browser-side debugging. Prefer this whenever the main challenge is UI behavior or design quality.",
      "mode": "all",
      "model": "litellm/google/gemini-3.1-pro-preview",
      "variant": "high",
      "permission": {
        "chrome-devtools*": "allow"
      }
    },
    "summary": {
      "model": "litellm/openrouter/free"
    },
    "title": {
      "model": "litellm/openrouter/free"
    },
    "compaction": {
      "model": "litellm/google/gemini-3.1-flash-lite-preview"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": [
        "bunx",
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth"
    },
    "deepwiki": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "grep-app": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "lsp": {
    "biome": {
      "command": [
        "biome",
        "lsp-proxy"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".json",
        ".jsonc",
        ".css",
        ".html"
      ]
    }
  },
  "formatter": {
    "stylua": {
      "command": [
        "stylua",
        "--search-parent-directories",
        "--stdin-filepath",
        "$FILE"
      ],
      "extensions": [
        ".lua",
        ".luau"
      ]
    },
    "markdownlint-cli2": {
      "command": [
        "markdownlint-cli2",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ]
    }
  },
  "provider": {
    "litellm": {
      "name": "LiteLLM",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:LITELLM_API_URL}",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "openai/gpt-5.4": {
          "name": "OpenAI GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "openai/gpt-5.4-mini": {
          "name": "OpenAI GPT-5.4 Mini",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "google/gemini-3.1-pro-preview": {
          "name": "Google Gemini 3.1 Pro Preview",
          "limit": {
            "context": 1048576,
            "output": 128000
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "google/gemini-3-flash-preview": {
          "name": "Google Gemini 3 Flash Preview",
          "limit": {
            "context": 1048576,
            "output": 128000
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "google/gemini-3.1-flash-lite-preview": {
          "name": "Google Gemini 3.1 Flash Lite Preview",
          "limit": {
            "context": 1048576,
            "output": 128000
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "openrouter/free": {
          "name": "OpenRouter Free",
          "limit": {
            "context": 128000,
            "output": 4096
          }
        }
      }
    }
  },
  "username": "Ian"
}
